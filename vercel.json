{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/analyze", "dest": "server.js" },
    { "src": "/logo.png", "dest": "server.js" },
    { "src": "/compass_rose.png", "dest": "server.js" },
    { "src": "/favicon.png", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
